meta {
  name: 02 Auth Captcha
  type: http
  seq: 2
}

get {
  url: __BASE_URL__/auth/captcha
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("captcha endpoint responds successfully", function () {
    expect(res.getStatus()).to.equal(200);
    const body = res.getBody();
    expect(body.code).to.equal("200");
    expect(body.data.uuid).to.not.equal(undefined);
    expect(body.data.base64).to.not.equal(undefined);
  });
}
